<body>
    <div class="navigationcontainer">
       <div class="title">
           <h3 class="changecolor">Alia's Life</h3>
       </div>
        <div class="pagecontainer">
            <a href="../index.html" class="mainlink link">
                <img src="../pictures/star.png" alt="" class="icon"> Main          
            </a>
            <a href="friends.html" class="link">
                 <img src="../pictures/heart.png" alt="" class="icon"> Friends    
            </a>
            <a href="about.html" class="link">
