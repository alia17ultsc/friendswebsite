<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Friends</title>
    <link rel="stylesheet" href="../css/style.css">
    <link rel="stylesheet" href="../css/friends.css">
    <script src="../javascript/slideshow.js" defer>
    </script>
    <script src="../javascript/menuscript.js" defer></script>
